{
  "name": "youtube-top-videos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --use-system-ca --watch server/index.js",
    "dev:client": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node --use-system-ca server/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "docx": "^9.6.1",
    "lucide-react": "^0.561.0",
    "pdfkit": "^0.18.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7"
  }
}
