{
  "name": "ai-whatsapp-learning-bot",
  "version": "1.0.0",
  "description": "Daily AI learning questions, answers, and weekly recaps for WhatsApp.",
  "main": "src/index.js",
  "scripts": {
    "init-db": "node scripts/initDb.js",
    "generate": "node --use-system-ca scripts/testGenerate.js",
    "send:questions": "node --use-system-ca src/jobs/sendDailyQuestions.js",
    "send:answers": "node --use-system-ca src/jobs/sendDailyAnswers.js",
    "send:recap": "node --use-system-ca src/jobs/sendWeeklyRecap.js",
    "start": "node --use-system-ca src/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "node-schedule": "^2.1.1",
    "playwright": "^1.59.1",
    "sqlite3": "^5.1.7"
  }
}

