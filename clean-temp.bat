@echo off
powershell.exe -ExecutionPolicy Bypass -Command "$tempPath = $env:TEMP; Write-Host '====================================' -ForegroundColor Cyan; Write-Host 'Temp File Cleanup Script' -ForegroundColor Cyan; Write-Host '====================================' -ForegroundColor Cyan; Write-Host ''; $beforeFiles = Get-ChildItem -Path $tempPath -Recurse -ErrorAction SilentlyContinue | Measure-Object; $beforeSize = (Get-ChildItem -Path $tempPath -Recurse -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum; Write-Host 'Before cleanup:' -ForegroundColor Yellow; Write-Host ('  Files: ' + $beforeFiles.Count) -ForegroundColor White; Write-Host ('  Size: ' + [math]::Round($beforeSize/1MB, 2) + ' MB') -ForegroundColor White; Write-Host ''; Write-Host 'Cleaning temp files...' -ForegroundColor Yellow; try { Remove-Item -Path \"$tempPath\*\" -Recurse -Force -ErrorAction SilentlyContinue; Write-Host 'Cleanup completed!' -ForegroundColor Green } catch { Write-Host 'Some files could not be deleted (likely in use)' -ForegroundColor Yellow }; $afterFiles = Get-ChildItem -Path $tempPath -Recurse -ErrorAction SilentlyContinue | Measure-Object; $afterSize = (Get-ChildItem -Path $tempPath -Recurse -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum; Write-Host ''; Write-Host 'After cleanup:' -ForegroundColor Yellow; Write-Host ('  Files: ' + $afterFiles.Count) -ForegroundColor White; Write-Host ('  Size: ' + [math]::Round($afterSize/1MB, 2) + ' MB') -ForegroundColor White; Write-Host ''; $deletedFiles = $beforeFiles.Count - $afterFiles.Count; $freedSpace = $beforeSize - $afterSize; Write-Host ('Deleted: ' + $deletedFiles + ' files') -ForegroundColor Green; Write-Host ('Freed: ' + [math]::Round($freedSpace/1MB, 2) + ' MB') -ForegroundColor Green"
